# Qilin preview runtime cache
.qilin-cache/

# Generated previews and releases
previews/*.png
previews/*.json
release/*.zip
release/*.json

# Python
__pycache__/
*.py[cod]
.pytest_cache/

# Commit the canonical current preview while ignoring other generated previews.
!previews/current.png
!previews/current_128x128.png
!previews/current.json
